{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "scopeName": "source.gaboscript",
    "fileTypes": ["gabo"],
    "name": "GaboScript Syntax",
    "patterns": [
        { "include": "#literals" },
        { "include": "#declarations" },
        { "include": "#keywords" },
        { "include": "#types" },
        { "include": "#operators" },
        { "include": "#punctuation" },
        { "include": "#function_call" },
        { "include": "#identifiers" },
        { "include": "#array_access" }
    ],

    "repository": {
        "expressions": {
            "patterns": [
                { "include": "#literals" },
                { "include": "#keywords" },
                { "include": "#punctuation" },
                { "include": "#identifiers" },
                { "include": "#array_access" }
            ]
        },

        "declarations": {
            "patterns": [
                {
                    "name": "variable.declaration.program.gabo",
                    "match": "(?i)(\\bAlgoritmo\\b)\\s*(.*)",
                    "captures": {
                        "1": { "name": "keyword.other.gabo" },
                        "2": { "name": "entity.name.function.gabo" }
                    }
                },
                {
                    "name": "variable.declaration.gabo",
                    "match": "(?i)\\b(var)\\b\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
                    "captures": {
                        "1": { "name": "storage.type.gabo" },
                        "2": { "name": "entity.name.variable.gabo" }
                    }
                },
                {
                    "name": "entity.name.function.gabo",
                    "begin": "\\b(?i:(Funcion|Procedimiento))\\b\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
                    "end": "\\)",
                    "beginCaptures": {
                        "1": { "name": "keyword.other.gabo" },
                        "2": { "name": "entity.name.function.gabo" }
                    },
                    "endCaptures": {
                        "1": { "name": "punctuation.definition.parameters.end.gabo" }
                    },
                    "patterns": [{ "include": "#expressions" }]
                }
            ]
        },

        "function_call": {
            "name": "entity.name.function.call.gabo",
            "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b(?=\\s*\\()"
        },

        "array_access": {
            "begin": "\\[",
            "beginCaptures": {
                "0": {
                    "name": "meta.brace.square.gabo"
                }
            },
            "end": "]",
            "endCaptures": {
                "0": {
                    "name": "meta.brace.square.gabo"
                }
            },
            "name": "meta.array.literal.gabo",
            "patterns": [
                { "include": "#comments" },
                { "include": "#numbers" },
                { "include": "#identifiers" },
                { "include": "$self" }
            ]
        },

        "identifiers": {
            "name": "variable.other.gabo",
            "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        },
        "types": {
            "patterns": [
                {
                    "name": "entity.name.type.gabo",
                    "match": "(?i)\\b(entero|cadena|booleano|real|caracter|E|S)\\b"
                }
            ]
        },

        "operators": {
            "patterns": [
                {
                    "name": "support.function.gabo",
                    "match": "(?i)\\b(Mostrar|Leer)\\b"
                },
                {
                    "name": "keyword.operator.assignment.gabo",
                    "match": "<<|\\="
                },
                {
                    "name": "keyword.operator.arithmetic.gabo",
                    "match": "[\\^+\\-*/%]"
                },
                {
                    "name": "keyword.operator.comparison.gabo",
                    "match": "[=<>]|==|!=|<=|>="
                },
                {
                    "name": "keyword.operator.logical.gabo",
                    "match": "(?i)\\b(And|Or)\\b"
                }
            ]
        },

        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.gabo",
                    "match": "(?i)\\b(Si|Entonces|Fin_Si|Sino|Para|Hacer|Fin_Para|Repetir|Hasta|Mientras|Fin_Mientras|En_Caso|Sea|Fin_Caso|Caso|Otro_Caso|Devolver|Fin_Repetir)\\b"
                },
                {
                    "name": "keyword.other.gabo",
                    "match": "(?i)\\b(Algoritmo|Inicio|Fin|Procedimiento|Fin_Procedimiento|Funcion|Fin_Funcion|Registro|Fin_Registro)\\b"
                },
                { "include": "#types" },
				{ "include": "#operators" }
            ]
        },

        "punctuation": {
            "patterns": [
                { "name": "punctuation.separator.gabo", "match": "[;,:]" },
                { "name": "punctuation.bracket.round.gabo", "match": "[()]" },
                { "name": "meta.brace.square.gabo", "match": "[[]]" }
            ]
        },

        "comments": {
            "patterns": [
                {
                    "name": "comment.block.gabo",
                    "begin": "/\\*",
                    "end": "\\*/",
                    "captures": {
                        "0": { "name": "punctuation.definition.comment.gabo" }
                    }
                },
                {
                    "name": "comment.line.double-slash.gabo",
                    "match": "//.*$"
                }
            ]
        },

        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.gabo",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [{ "name": "constant.character.escape.gabo", "match": "\\\\." }]
                }
            ]
        },

        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.gabo",
                    "match": "\\b\\d+(\\.\\d+)?\\b"
                }
            ]
        },

        "literals": {
            "patterns": [{ "include": "#numbers" }, { "include": "#strings" }, { "include": "#comments" }]
        }
    }
}
