{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "scopeName": "source.gaboscript",
    "fileTypes": ["gabo"],
    "name": "GaboScript Syntax",
    "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#numbers" },
        { "include": "#declarations" },
        { "include": "#keywords" },
        { "include": "#types" },
        { "include": "#operators" },
        { "include": "#punctuation" },
        { "include": "#function_call"},
        { "include": "#variable_usage" },
        { "include": "#array_access" }
    ],

    "repository": {
        "expressions": {
            "patterns": [
                { "include": "#comments" },
                { "include": "#strings" },
                { "include": "#numbers" },
                { "include": "#keywords" },
                { "include": "#types" },
                { "include": "#operators" },
                { "include": "#punctuation" },
                { "include": "#variable_usage" },
                { "include": "#array_access" }
            ]
        },

        "comments": {
            "patterns": [
                {
                    "name": "comment.block.gaboscript",
                    "begin": "/\\*",
                    "end": "\\*/",
                    "captures": {
                        "0": { "name": "punctuation.definition.comment.gaboscript" }
                    }
                },
                {
                    "name": "comment.line.double-slash.gaboscript",
                    "match": "//.*$"
                }
            ]
        },

        "declarations": {
            "patterns": [
                {
                    "name": "variable.declaration.program.gaboscript",
                    "match": "(?i)(\\bAlgoritmo\\b)\\s*(.*)",
                    "captures": {
                        "1": { "name": "keyword.other.gaboscript" },
                        "2": { "name": "entity.name.function.gaboscript" }
                    }
                },
                {
                    "name": "variable.declaration.gaboscript",
                    "match": "(?i)\\b(var)\\b\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
                    "captures": {
                        "1": { "name": "storage.type.gaboscript" },
                        "2": { "name": "entity.name.variable.gaboscript" }
                    }
                },
                {
                    "name": "entity.name.function.gaboscript",
                    "begin": "\\b(?i:(Funcion|Procedimiento))\\b\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
                    "end": "\\)",
                    "beginCaptures": {
                        "1": { "name": "keyword.other.gaboscript" },
                        "2": { "name": "entity.name.function.gaboscript" }
                    },
                    "endCaptures": {
                        "1": { "name": "punctuation.definition.parameters.end.gaboscript" }
                    },
                    "patterns": [
                        { "include": "#expressions"}
                    ]
                }
            ]
        },

        "function_call": {
            "name": "entity.name.function.call.gaboscript",
            "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b(?=\\s*\\()"
        },

        "array_access": {
            "begin": "\\[",
            "beginCaptures": {
                "0": {
                    "name": "meta.brace.square.gaboscript"
                }
            },
            "end": "]",
            "endCaptures": {
                "0": {
                    "name": "meta.brace.square.gaboscript"
                }
            },
            "name": "meta.array.literal.gaboscript",
            "patterns": [
                { "include": "#comments" },
                { "include": "#numbers" },
                { "include": "#variable_usage" },
                { "include": "$self" }
            ]
        },

        "variable_usage": {
            "name": "variable.other.gaboscript",
            "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        },

        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.gaboscript",
                    "match": "(?i)\\b(Si|Entonces|Fin_Si|Sino|Para|Hacer|Fin_Para|Repetir|Hasta|Mientras|Fin_Mientras|En_Caso|Sea|Fin_Caso|Caso|Otro_Caso|Devolver|Fin_Repetir)\\b"
                },
                {
                    "name": "keyword.other.gaboscript",
                    "match": "(?i)\\b(Algoritmo|Inicio|Fin|Procedimiento|Fin_Procedimiento|Funcion|Fin_Funcion|Registro|Fin_Registro)\\b"
                }
            ]
        },

        "types": {
            "patterns": [
                {
                    "name": "entity.name.type.gaboscript",
                    "match": "(?i)\\b(entero|cadena|booleano|real|caracter|E|S)\\b"
                }
            ]
        },

        "operators": {
            "patterns": [
                {
                    "name": "support.function.gaboscript",
                    "match": "(?i)\\b(Mostrar|Leer)\\b"
                },
                {
                    "name": "keyword.operator.assignment.gaboscript",
                    "match": "<<|\\="
                },
                {
                    "name": "keyword.operator.arithmetic.gaboscript",
                    "match": "[\\^+\\-*/%]"
                },
                {
                    "name": "keyword.operator.comparison.gaboscript",
                    "match": "[=<>]|==|!=|<=|>="
                },
                {
                    "name": "keyword.operator.logical.gaboscript",
                    "match": "(?i)\\b(And|Or)\\b"
                }
            ]
        },

        "punctuation": {
            "patterns": [
                { "name": "punctuation.separator.gaboscript", "match": "[;,:]" },
                { "name": "punctuation.bracket.round.gaboscript", "match": "[()]" }
            ]
        },

        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.gaboscript",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [{ "name": "constant.character.escape.gaboscript", "match": "\\\\." }]
                }
            ]
        },

        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.gaboscript",
                    "match": "\\b\\d+(\\.\\d+)?\\b"
                }
            ]
        }
    }
}
