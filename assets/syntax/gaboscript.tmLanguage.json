{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "scopeName": "source.gaboscript",
    "fileTypes": ["gabo"],
    "name": "GaboScript Syntax",
    "patterns": [{ "include": "#declarations" }, { "include": "#expressions" }],

    "repository": {
        "punctuation": {
            "patterns": [
                { "name": "meta.separator.parameter.gabo", "match": "," },
                {
                    "name": "punctuation.separator.key-value.gabo",
                    "match": "[:]"
                },
                { "name": "meta.brace.round.gabo", "match": "[()]" },
                { "name": "meta.brace.square.gabo", "match": "[\\[\\]]" }
            ]
        },

        "expressions": {
            "patterns": [
                { "include": "#punctuation" },
                { "include": "#literals" },
                { "include": "#keywords" },
                { "include": "#function_call" },
                { "include": "#identifiers" }
            ]
        },

        "declarations": {
            "patterns": [
                {
                    "name": "variable.declaration.program.gabo",
                    "match": "(?i)(\\bAlgoritmo\\b)\\s*(.*)",
                    "captures": {
                        "1": { "name": "keyword.other.gabo" },
                        "2": { "name": "entity.name.function.gabo" }
                    }
                }
            ]
        },

        "function_call": {
            "name": "entity.name.function.call.gabo",
            "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b(?=\\s*\\()"
        },

        "identifiers": {
            "name": "variable.other.gabo",
            "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        },

        "types": {
            "patterns": [
                {
                    "name": "entity.name.type.gabo",
                    "match": "(?i)\\b(entero|cadena|booleano|real|caracter)\\b"
                },
                {
                    "match": "(?i)(E\\s*/\\s*S|E|S)\\s*(:)",
                    "captures": {
                        "1": {
                            "name": "entity.name.type.gabo"
                        },
                        "2": {
                            "name": "punctuation.separator.key-value.gabo"
                        }
                    }
                }
            ]
        },

        "operators": {
            "patterns": [
                {
                    "name": "support.function.gabo",
                    "match": "(?i)\\b(Mostrar|Leer|Imprimir)\\b"
                },
                {
                    "name": "keyword.operator.assignment.gabo",
                    "match": "<<|\\="
                },
                {
                    "name": "keyword.operator.arithmetic.gabo",
                    "match": "[\\^+\\-*/%]"
                },
                {
                    "name": "keyword.operator.comparison.gabo",
                    "match": "[=<>]|==|!=|<=|>="
                },
                {
                    "name": "keyword.operator.logical.gabo",
                    "match": "(?i)\\b(And|Or)\\b"
                }
            ]
        },

        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.gabo",
                    "match": "(?i)\\b(Si|Entonces|Fin_Si|Sino|Para|Hacer|Fin_Para|Repetir|Hasta|Mientras|Fin_Mientras|En_Caso|Sea|Fin_Caso|Caso|Otro_Caso|Devolver|Fin_Repetir)\\b"
                },
                {
                    "name": "keyword.other.gabo",
                    "match": "(?i)\\b(Algoritmo|Inicio|Fin|Procedimiento|Fin_Procedimiento|Funcion|Fin_Funcion|Registro|Fin_Registro|var)\\b"
                },
                { "include": "#types" },
                { "include": "#operators" }
            ]
        },

        "comments": {
            "patterns": [
                {
                    "name": "comment.block.gabo",
                    "begin": "/\\*",
                    "end": "\\*/",
                    "captures": {
                        "0": { "name": "punctuation.definition.comment.gabo" }
                    }
                },
                {
                    "name": "comment.line.double-slash.gabo",
                    "match": "//.*$"
                }
            ]
        },

        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.gabo",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.gabo",
                            "match": "\\\\."
                        }
                    ]
                }
            ]
        },

        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.gabo",
                    "match": "\\b\\d+(\\.\\d+)?\\b"
                }
            ]
        },

        "literals": {
            "patterns": [
                { "include": "#numbers" },
                { "include": "#strings" },
                { "include": "#comments" }
            ]
        }
    }
}
