{
    "name": "gaboscript",
    "displayName": "GaboScript",
    "description": "Soporte para el lenguaje educativo GaboScript, incluyendo resaltado de sintaxis y autocompletado.",
    "version": "0.0.4",
    "publisher": "Las Nuevas Victimas De Elecentro",
    "icon": "GS.png",
	"type": "module",
    "engines": {
        "vscode": "^1.105.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "main": "./extension/src/main.js",
    "activationEvents": [
        "onLanguage:gaboscript",
        "onCommand:gaboscript.exportarADOCX"
    ],
    "contributes": {
        "languages": [
            {
                "id": "gaboscript",
                "aliases": [
                    "GaboScript",
                    "gaboscript",
					"gs",
					"gabo"
                ],
                "extensions": [
                    ".gabo"
                ],
                "configuration": "./extension/language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "gaboscript",
                "scopeName": "source.gaboscript",
                "path": "./extension/syntax/gaboscript.tmLanguage.json"
            }
        ],
        "snippets": [
            {
                "language": "gaboscript",
                "path": "./extension/snippets/gaboscript.json"
            }
        ],
        "commands": [
            {
                "command": "gaboscript.exportarADOCX",
                "title": "Exportar a DOCX",
                "category": "GaboScript",
                "icon": {
                    "light": "./extension/icons/docx-export.svg",
                    "dark": "./extension/icons/docx-export.svg"
                }
            }
        ],
        "menus": {
            "editor/title": [
                {
                    "command": "gaboscript.exportarADOCX",
                    "group": "navigation",
                    "when": "resourceExtName == .gabo"
                }
            ],
            "editor/context": [
                {
                    "command": "gaboscript.exportarADOCX",
                    "group": "navigation"
                }
            ],
            "explorer/context": [
                {
                    "command": "gaboscript.exportarADOCX",
                    "group": "navigation"
                }
            ]
        },
        "iconThemes": [
            {
                "id": "gaboscript-icon",
                "label": "GaboScript Icon",
                "path": "./extension/icons/file-icon-theme.json"
            }
        ]
    }
}
