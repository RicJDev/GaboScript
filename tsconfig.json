{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ES2022",
        "moduleResolution": "bundler",
        "strict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "exactOptionalPropertyTypes": false,
        "sourceMap": true,
        "outDir": "out",
        "rootDir": "src",
        "skipLibCheck": true
    },
    "include": ["src"]
}
